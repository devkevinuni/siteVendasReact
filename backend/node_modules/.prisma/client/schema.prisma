generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

model Product {
  id         Int      @id @default(autoincrement())
  nome       String
  descricao  String
  preco      Decimal
  categoria  String
  imagem_url String
  estoque    Int
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  @@map("products")
}
